{
  "Logging": {
    "LogLevel": {
      "Default":      "Information",
      "LogCollector": "Debug"
    }
  },

  "LogSinks": [
    {
      // Console shows parsed entries immediately — useful when testing the parser.
      "Type": "Console"
    },
    {
      "Type": "Sqlite",
      "ConnectionString": "Data Source=dev-logs.db"
    }
  ],

  "SyslogListener": {
    // Unprivileged port — no root or setcap needed in development.
    // Test: echo "<30>Jun  4 18:00:00 mtk-router : firewall,info test" | nc -u -w1 localhost 5140
    "Port": 5140
  },

  "BatchWriter": {
    "BatchSize":    10,
    "BatchTimeout": "00:00:01"
  }
}
