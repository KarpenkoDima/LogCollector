{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "LogSinks": [
    {
      "Type": "Sqlite",
      "ConnectionString": "Data Source=logs.db"
    },
    {
      "Type": "Loki",
      "Endpoint": "http://localhost:3100"
    }
  ],
  "SyslogListener": {
    "Port": 514
  }
}